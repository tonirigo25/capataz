{
  "name": "capataz",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build && node scripts/prepare-standalone.mjs",
    "start": "node scripts/start-standalone.mjs",
    "typecheck": "prisma generate && tsc --noEmit",
    "test:ai": "node scripts/validate-capataz-ai.mjs",
    "test:chat-parser": "node scripts/validate-chat-parser.mjs",
    "test:chat-engine": "node scripts/validate-chat-engine.mjs",
    "test:chat-conversations": "node scripts/validate-chat-conversations.mjs",
    "test:chat-query": "node scripts/validate-chat-query.mjs",
    "test:chat-routing": "node scripts/validate-chat-routing.mjs",
    "test:dashboard-hoy": "node scripts/validate-dashboard-hoy.mjs",
    "test:crm-clientes": "node scripts/validate-crm-clientes.mjs",
    "test:document-pdf": "node scripts/validate-document-pdf.mjs",
    "test:works": "node scripts/validate-works.mjs",
    "test:work-detail": "node scripts/validate-work-detail.mjs",
    "test:work-profitability": "node scripts/validate-work-profitability.mjs",
    "test:work-chat": "node scripts/validate-work-chat.mjs",
    "test:contacts": "node scripts/validate-contacts.mjs",
    "test:documents": "node scripts/validate-documents.mjs",
    "test:internal-notes": "node scripts/validate-internal-notes.mjs",
    "test:agenda": "node scripts/validate-agenda.mjs",
    "test:notifications": "node scripts/validate-notifications.mjs",
    "test:global-search": "node scripts/validate-global-search.mjs",
    "test:settings": "node scripts/validate-settings.mjs",
    "test:block2-integration": "node scripts/validate-block2-integration.mjs",
    "test:business-periods": "node scripts/validate-business-periods.mjs",
    "test:business-metrics": "node scripts/validate-business-metrics.mjs",
    "test:business-health": "node scripts/validate-business-health.mjs",
    "test:business-intelligence": "node scripts/validate-business-intelligence.mjs",
    "test:business-chat": "node scripts/validate-business-chat.mjs",
    "db:deploy": "prisma generate && prisma migrate deploy",
    "db:push": "prisma db push && npm run db:seed",
    "db:seed": "node prisma/seed.js",
    "db:studio": "prisma studio",
    "mobile:sync": "cap sync",
    "mobile:sync:android": "cap sync android",
    "mobile:sync:ios": "cap sync ios",
    "mobile:open:android": "cap open android",
    "mobile:open:ios": "cap open ios",
    "mobile:android:aab": "cd android && gradlew.bat bundleRelease",
    "mobile:ios:open": "cap open ios"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@prisma/client": "^6.10.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "^15.3.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "prisma": "^6.10.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
