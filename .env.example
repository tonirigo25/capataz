DATABASE_URL=
# Optional. Enables automatic document extraction; leave empty for manual mode.
OPENAI_API_KEY=
# Optional local document root. Defaults to .capataz-documents outside public/.
DOCUMENT_STORAGE_ROOT=
# Optional: openai (default when configured) or deterministic (tests/development only).
DOCUMENT_EXTRACTION_PROVIDER=
# Optional model used by the document reader.
OPENAI_DOCUMENT_MODEL=
OPENAI_MODEL_FAST=gpt-4.1-mini
OPENAI_MODEL_REASONING=gpt-5.5
OPENAI_REASONING_EFFORT=low
OPENAI_MODEL=gpt-5.5
OPENAI_TIMEOUT_MS=18000
OPENAI_FAST_TIMEOUT_MS=10000
OPENAI_REASONING_TIMEOUT_MS=30000
NEXT_PUBLIC_APP_MODE=test
NEXT_PUBLIC_APP_ENV=staging
NEXT_PUBLIC_WEB_BASE_URL=
NEXT_PUBLIC_SUPPORT_EMAIL=soporte@capataz.app

# Mobile wrapper: release (safe default), staging or development.
CAPATAZ_MOBILE_MODE=release
CAPATAZ_MOBILE_SERVER_URL=

# Identity and transactional email (never commit real values)
APP_BASE_URL=http://localhost:3000
EMAIL_FROM=
RESEND_API_KEY=
AUTH_SESSION_DAYS=30
AUTH_VERIFICATION_TOKEN_MINUTES=1440
AUTH_RESET_TOKEN_MINUTES=30
AUTH_MAX_LOGIN_ATTEMPTS=5
AUTH_LOCK_MINUTES=15
