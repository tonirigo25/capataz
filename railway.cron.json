{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "node --check scripts/run-proactive-evaluation.mjs"
  },
  "deploy": {
    "startCommand": "npm run proactive:evaluate",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 1
  }
}
