generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ClientStatus {
  nuevo
  pendiente_datos
  visita_pendiente
  presupuesto_pendiente
  presupuesto_enviado
  seguimiento_pendiente
  aceptado
  rechazado
  obra_activa
  finalizado
  pendiente_cobro
}

enum WorkStatus {
  borrador
  pendiente_aprobacion
  planificada
  preparacion
  pendiente_inicio
  en_curso
  pausada
  parcialmente_terminada
  pendiente_material
  pendiente_cliente
  parada
  pendiente_remates
  finalizada
  facturada_parcialmente
  facturada
  pendiente_cobro
  cobrada
  cerrada
  archivada
}

enum WorkPriority {
  baja
  media
  alta
  urgente
}

enum BudgetStatus {
  borrador
  pendiente_revision
  enviado
  visto
  pendiente_respuesta
  aceptado
  rechazado
  caducado
}

enum InvoiceStatus {
  borrador
  pendiente_emitir
  emitida
  enviada
  pendiente
  pendiente_pago
  parcialmente_pagada
  pagada
  vencida
  reclamada
}

enum PaymentType {
  senal
  pago_parcial
  pago_final
  regularizacion
}

enum ExpenseCategory {
  material
  mano_obra
  transporte
  herramienta
  gasolina
  subcontrata
  otros
}

enum ExpenseCashStatus {
  unknown
  pending
  paid
  cancelled
}

enum CostBehavior {
  unknown
  fixed
  variable
}

enum FinancialAccountType {
  bank
  cash
  other
}

enum CashMovementType {
  inflow
  outflow
  transfer_in
  transfer_out
  adjustment
}

enum CashMovementStatus {
  pending
  confirmed
  cancelled
}

enum CashMovementSource {
  manual
  generated
  adjustment
  bank_import
}

enum RecurringExpenseFrequency {
  weekly
  monthly
  quarterly
  yearly
  custom
}

enum ExpectedCashFlowType {
  expected_inflow
  expected_outflow
}

enum ExpectedCashFlowStatus {
  pending
  confirmed
  cancelled
}

enum ExpectedCashFlowSource {
  manual
  invoice
  expense
  recurring
  budget
  scenario
}

enum MaterialStatus {
  pendiente
  comprado
  entregado
  falta
  devuelto
}

enum ReminderType {
  seguimiento_presupuesto
  recordatorio_factura
  factura_vencida
  pedir_fotos
  pedir_medidas
  confirmar_visita
  material_pendiente
  recordatorio_interno
}

enum ReminderChannel {
  interno
  whatsapp
  email
}

enum ReminderStatus {
  borrador
  pendiente_confirmacion
  programado
  enviado
  cancelado
  fallido
  realizado
}

enum EventoAgendaTipo {
  visita
  llamada
  seguimiento_presupuesto
  seguimiento_cobro
  inicio_obra
  fin_previsto_obra
  compra_material
  recordatorio_interno
  vencimiento_factura
  presupuesto_pendiente
  tarea_obra
}

enum EventoAgendaEstado {
  pendiente
  confirmado
  realizado
  reprogramado
  cancelado
}

enum DocumentCategory {
  presupuesto
  factura
  contrato
  albaran
  ticket
  fotografia
  garantia
  certificado
  plano
  informe
  otro
}

enum NotificationPriority {
  baja
  media
  alta
  critica
}

enum BusinessSignalLevel {
  info
  atencion
  importante
  critico
}

enum BusinessSignalStatus {
  active
  snoozed
  dismissed
  resolved
  expired
}

enum BusinessSignalSource {
  crm
  obras
  facturas
  cobros
  tesoreria
  agenda
  documentos
  materiales
  rentabilidad
  chat
  recordatorios
  visitas
  gastos
  presupuestos
  datos
}

enum BusinessRecommendationStatus {
  active
  viewed
  accepted
  in_progress
  completed
  snoozed
  dismissed
  obsolete
  failed
}

enum RecommendationActionLogStatus {
  pending
  success
  failed
  skipped
}

enum AutomationDefinitionStatus {
  draft
  active
  paused
  disabled
  archived
}

enum AutomationVersionStatus {
  draft
  published
  retired
}

enum AutomationRunStatus {
  queued
  running
  waiting_confirmation
  completed
  partial
  failed
  skipped
  cancelled
  duplicate
}

enum AutomationStepStatus {
  pending
  running
  waiting_confirmation
  completed
  failed
  skipped
  cancelled
}

enum TaskStatus {
  inbox
  planned
  in_progress
  blocked
  waiting
  completed
  cancelled
  archived
}

enum TaskPriority {
  low
  medium
  high
  urgent
}

enum FollowUpStatus {
  planned
  due
  in_progress
  waiting_response
  promised
  completed
  unsuccessful
  cancelled
  archived
}

enum FollowUpPriority {
  low
  medium
  high
  urgent
}

enum UserStatus {
  pending_verification
  active
  suspended
  archived
}

enum CompanyStatus {
  active
  suspended
  archived
}

enum CompanyRole {
  OWNER
  ADMIN
  MANAGER
  MEMBER
  VIEWER
}

enum MembershipStatus {
  invited
  active
  suspended
  archived
}

enum SecurityAuditOutcome {
  success
  failure
  blocked
}

model Client {
  id                        String             @id @default(cuid())
  companyId                 String?
  nombre                    String
  nombreComercial           String?
  razonSocial               String?
  nifCif                    String?
  telefono                  String
  email                     String?
  direccion                 String
  direccionFiscal           String?
  codigoPostal              String?
  municipio                 String?
  provincia                 String?
  pais                      String             @default("España")
  emailFacturacion          String?
  telefonoFacturacion       String?
  contactoPrincipalNombre   String?
  contactoPrincipalCargo    String?
  contactoPrincipalTelefono String?
  contactoPrincipalEmail    String?
  contactoFacturacionNombre String?
  tipo                      String
  estado                    ClientStatus       @default(nuevo)
  origen                    String
  notas                     String?
  fechaCreacion             DateTime           @default(now())
  ultimaInteraccion         DateTime?
  archivadoAt               DateTime?
  budgets                   Budget[]
  contacts                  Contact[]
  documents                 Document[]
  expenses                  Expense[]
  invoices                  Invoice[]
  internalNotes             InternalNote[]
  payments                  Payment[]
  cashMovements             CashMovement[]
  expectedCashFlows         ExpectedCashFlow[]
  reminders                 Reminder[]
  works                     Work[]
  agendaEvents              EventoAgenda[]
  company                   Company?           @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([nombre])
  @@index([nifCif])
  @@index([email])
  @@index([telefono])
  @@index([estado])
  @@index([archivadoAt])
  @@index([companyId])
}

model Work {
  id                    String             @id @default(cuid())
  companyId             String?
  numeroInterno         String?
  codigo                String?
  clienteId             String
  contactoId            String?
  contactoPrincipal     String?
  contactoTelefono      String?
  contactoEmail         String?
  titulo                String
  direccion             String
  latitud               Float?
  longitud              Float?
  tipoTrabajo           String
  estado                WorkStatus         @default(pendiente_inicio)
  prioridad             WorkPriority       @default(media)
  fechaCreacion         DateTime           @default(now())
  fechaInicioPrevista   DateTime?
  fechaInicio           DateTime?
  fechaInicioReal       DateTime?
  fechaFinPrevista      DateTime?
  fechaFinReal          DateTime?
  responsable           String?
  comercial             String?
  jefeObra              String?
  descripcion           String?
  observacionesInternas String?
  notasPrivadas         String?
  presupuestoAprobado   Float
  costePrevisto         Float              @default(0)
  gastoReal             Float              @default(0)
  margenEstimado        Float              @default(0)
  horasEstimadas        Float              @default(0)
  horasReales           Float              @default(0)
  subcontratasCoste     Float              @default(0)
  archivada             Boolean            @default(false)
  archivadaAt           DateTime?
  notas                 String?
  updatedAt             DateTime           @updatedAt
  budgets               Budget[]
  client                Client             @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  contact               Contact?           @relation("WorkSiteContact", fields: [contactoId], references: [id], onDelete: SetNull)
  repositoryDocuments   Document[]
  documents             WorkDocument[]
  expenses              Expense[]
  internalNotes         InternalNote[]
  photos                WorkPhoto[]
  invoices              Invoice[]
  materials             Material[]
  payments              Payment[]
  cashMovements         CashMovement[]
  expectedCashFlows     ExpectedCashFlow[]
  recurringExpenses     RecurringExpense[]
  reminders             Reminder[]
  agendaEvents          EventoAgenda[]
  company               Company?           @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@unique([companyId, numeroInterno])
  @@unique([companyId, codigo])
  @@index([estado])
  @@index([prioridad])
  @@index([fechaInicioPrevista])
  @@index([fechaFinPrevista])
  @@index([archivada])
  @@index([contactoId])
  @@index([companyId])
}

model Contact {
  id               String         @id @default(cuid())
  companyId        String?
  clientId         String
  nombre           String
  apellidos        String?
  cargo            String?
  telefono         String?
  email            String?
  isPrimary        Boolean        @default(false)
  isBillingContact Boolean        @default(false)
  isSiteContact    Boolean        @default(false)
  notes            String?
  archivedAt       DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  client           Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  agendaEvents     EventoAgenda[]
  reminders        Reminder[]
  worksAsSite      Work[]         @relation("WorkSiteContact")
  company          Company?       @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([clientId])
  @@index([email])
  @@index([telefono])
  @@index([archivedAt])
  @@index([companyId])
}

model WorkDocument {
  id         String   @id @default(cuid())
  obraId     String
  tipo       String
  nombre     String
  url        String?
  entityType String?
  entityId   String?
  notas      String?
  fecha      DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  work       Work     @relation(fields: [obraId], references: [id], onDelete: Cascade)

  @@index([obraId])
  @@index([tipo])
  @@index([entityType, entityId])
}

model WorkPhoto {
  id         String    @id @default(cuid())
  obraId     String
  documentId String?   @unique
  categoria  String
  titulo     String
  url        String?
  autor      String?
  ubicacion  String?
  notas      String?
  tomadaEn   DateTime  @default(now())
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  document   Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)
  work       Work      @relation(fields: [obraId], references: [id], onDelete: Cascade)

  @@index([obraId])
  @@index([categoria])
}

model Budget {
  id               String         @id @default(cuid())
  companyId        String?
  clienteId        String
  obraId           String?
  numero           String
  titulo           String
  partidas         String
  subtotal         Float
  iva              Float
  descuento        Float          @default(0)
  total            Float
  margenEstimado   Float
  estado           BudgetStatus   @default(borrador)
  fechaCreacion    DateTime       @default(now())
  fechaEnvio       DateTime?
  fechaValidez     DateTime?
  fechaSeguimiento DateTime?
  condiciones      String?
  observaciones    String?
  formaPago        String?
  client           Client         @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  agendaEvents     EventoAgenda[]
  documents        Document[]
  internalNotes    InternalNote[]
  reminders        Reminder[]
  work             Work?          @relation(fields: [obraId], references: [id])
  company          Company?       @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@unique([companyId, numero])
  @@index([companyId])
}

model Invoice {
  id                String             @id @default(cuid())
  companyId         String?
  clienteId         String
  obraId            String?
  numero            String
  concepto          String
  partidas          String?
  importeBase       Float
  iva               Float
  total             Float
  pagado            Float              @default(0)
  pendiente         Float
  fechaEmision      DateTime
  fechaVencimiento  DateTime
  estado            InvoiceStatus      @default(pendiente_pago)
  observaciones     String?
  metodoPago        String?
  datosBancarios    String?
  cashMovements     CashMovement[]
  client            Client             @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  agendaEvents      EventoAgenda[]
  documents         Document[]
  expectedCashFlows ExpectedCashFlow[]
  internalNotes     InternalNote[]
  payments          Payment[]
  reminders         Reminder[]
  work              Work?              @relation(fields: [obraId], references: [id])
  company           Company?           @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@unique([companyId, numero])
  @@index([companyId])
}

model Payment {
  id            String         @id @default(cuid())
  companyId     String?
  facturaId     String
  clienteId     String
  obraId        String?
  importe       Float
  metodo        String
  fecha         DateTime       @default(now())
  tipo          PaymentType
  notas         String?
  cashMovements CashMovement[]
  client        Client         @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  invoice       Invoice        @relation(fields: [facturaId], references: [id], onDelete: Cascade)
  work          Work?          @relation(fields: [obraId], references: [id])
  company       Company?       @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([companyId])
}

model Expense {
  id                String             @id @default(cuid())
  companyId         String?
  obraId            String
  clienteId         String?
  proveedor         String
  concepto          String
  categoria         ExpenseCategory
  importe           Float
  fecha             DateTime
  paymentStatus     ExpenseCashStatus?
  paymentDueDate    DateTime?
  paidAt            DateTime?
  costBehavior      CostBehavior       @default(unknown)
  fotoTicketUrl     String?
  notas             String?
  cashMovements     CashMovement[]
  client            Client?            @relation(fields: [clienteId], references: [id])
  documents         Document[]
  expectedCashFlows ExpectedCashFlow[]
  work              Work               @relation(fields: [obraId], references: [id], onDelete: Cascade)
  company           Company?           @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([companyId])
}

model FinancialAccount {
  id                     String               @id @default(cuid())
  companyId              String?
  name                   String
  type                   FinancialAccountType @default(bank)
  currency               String               @default("EUR")
  openingBalance         Float                @default(0)
  currentManualBalance   Float?
  manualBalanceUpdatedAt DateTime?
  minimumBalance         Float?
  isActive               Boolean              @default(true)
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  archivedAt             DateTime?
  movements              CashMovement[]
  company                Company?             @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([isActive])
  @@index([archivedAt])
  @@index([companyId])
}

model CashMovement {
  id              String             @id @default(cuid())
  companyId       String?
  accountId       String
  type            CashMovementType
  amount          Float
  date            DateTime
  description     String
  invoiceId       String?
  paymentId       String?            @unique
  expenseId       String?            @unique
  workId          String?
  clientId        String?
  category        String?
  provider        String?
  status          CashMovementStatus @default(confirmed)
  source          CashMovementSource @default(manual)
  transferGroupId String?
  notes           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  archivedAt      DateTime?
  account         FinancialAccount   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  client          Client?            @relation(fields: [clientId], references: [id], onDelete: SetNull)
  expense         Expense?           @relation(fields: [expenseId], references: [id], onDelete: SetNull)
  invoice         Invoice?           @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  payment         Payment?           @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  work            Work?              @relation(fields: [workId], references: [id], onDelete: SetNull)
  company         Company?           @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([accountId, date])
  @@index([type])
  @@index([status])
  @@index([source])
  @@index([invoiceId])
  @@index([workId])
  @@index([clientId])
  @@index([transferGroupId])
  @@index([archivedAt])
  @@index([companyId])
}

model RecurringExpense {
  id                String                    @id @default(cuid())
  companyId         String?
  name              String
  amount            Float
  frequency         RecurringExpenseFrequency
  nextDueDate       DateTime
  category          String?
  workId            String?
  provider          String?
  fixedCost         Boolean                   @default(true)
  isActive          Boolean                   @default(true)
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  archivedAt        DateTime?
  work              Work?                     @relation(fields: [workId], references: [id], onDelete: SetNull)
  expectedCashFlows ExpectedCashFlow[]
  company           Company?                  @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([isActive, nextDueDate])
  @@index([workId])
  @@index([archivedAt])
  @@index([companyId])
}

model ExpectedCashFlow {
  id                 String                 @id @default(cuid())
  companyId          String?
  type               ExpectedCashFlowType
  amount             Float
  expectedDate       DateTime
  description        String
  probability        Float?
  confidenceSource   String?
  invoiceId          String?
  expenseId          String?
  recurringExpenseId String?
  workId             String?
  clientId           String?
  status             ExpectedCashFlowStatus @default(pending)
  source             ExpectedCashFlowSource @default(manual)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  archivedAt         DateTime?
  client             Client?                @relation(fields: [clientId], references: [id], onDelete: SetNull)
  expense            Expense?               @relation(fields: [expenseId], references: [id], onDelete: SetNull)
  invoice            Invoice?               @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  recurringExpense   RecurringExpense?      @relation(fields: [recurringExpenseId], references: [id], onDelete: SetNull)
  company            Company?               @relation(fields: [companyId], references: [id], onDelete: Restrict)
  work               Work?                  @relation(fields: [workId], references: [id], onDelete: SetNull)

  @@index([expectedDate])
  @@index([type, status])
  @@index([source])
  @@index([invoiceId])
  @@index([expenseId])
  @@index([workId])
  @@index([clientId])
  @@index([archivedAt])
  @@index([companyId])
}

model TreasurySettings {
  id                      String   @id @default(cuid())
  currency                String   @default("EUR")
  minimumCashBalance      Float?
  safetyBuffer            Float?
  targetCoverageDays      Int?
  includeEstimatedInflows Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  companyId               String?
  company                 Company? @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([companyId])
}

model Material {
  id        String         @id @default(cuid())
  companyId String?
  obraId    String
  nombre    String
  cantidad  String
  estado    MaterialStatus @default(pendiente)
  notas     String?
  work      Work           @relation(fields: [obraId], references: [id], onDelete: Cascade)
  company   Company?       @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([companyId])
}

model Reminder {
  id                   String          @id @default(cuid())
  companyId            String?
  clienteId            String?
  obraId               String?
  facturaId            String?
  presupuestoId        String?
  contactId            String?
  tipo                 ReminderType
  canal                ReminderChannel @default(interno)
  mensaje              String
  fechaProgramada      DateTime
  estado               ReminderStatus  @default(borrador)
  requiereConfirmacion Boolean         @default(true)
  confirmadoPorUsuario Boolean         @default(false)
  budget               Budget?         @relation(fields: [presupuestoId], references: [id])
  client               Client?         @relation(fields: [clienteId], references: [id])
  contact              Contact?        @relation(fields: [contactId], references: [id], onDelete: SetNull)
  invoice              Invoice?        @relation(fields: [facturaId], references: [id])
  work                 Work?           @relation(fields: [obraId], references: [id])
  agendaEvents         EventoAgenda[]
  company              Company?        @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([contactId])
  @@index([companyId])
}

model EventoAgenda {
  id                   String             @id @default(cuid())
  companyId            String?
  titulo               String
  descripcion          String?
  tipo                 EventoAgendaTipo
  estado               EventoAgendaEstado @default(pendiente)
  fechaInicio          DateTime
  fechaFin             DateTime?
  horaInicio           String?
  horaFin              String?
  clienteId            String?
  obraId               String?
  presupuestoId        String?
  facturaId            String?
  recordatorioId       String?
  contactId            String?
  taskId               String?
  followUpId           String?
  direccion            String?
  notas                String?
  requiereConfirmacion Boolean            @default(false)
  confirmadoPorUsuario Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  budget               Budget?            @relation(fields: [presupuestoId], references: [id])
  client               Client?            @relation(fields: [clienteId], references: [id])
  contact              Contact?           @relation(fields: [contactId], references: [id], onDelete: SetNull)
  invoice              Invoice?           @relation(fields: [facturaId], references: [id])
  reminder             Reminder?          @relation(fields: [recordatorioId], references: [id])
  work                 Work?              @relation(fields: [obraId], references: [id])
  task                 Task?              @relation(fields: [taskId], references: [id], onDelete: SetNull)
  followUp             FollowUp?          @relation(fields: [followUpId], references: [id], onDelete: SetNull)
  company              Company?           @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([contactId])
  @@index([taskId])
  @@index([followUpId])
  @@index([companyId])
}

model InternalNote {
  id         String    @id @default(cuid())
  companyId  String?
  clientId   String?
  workId     String?
  invoiceId  String?
  budgetId   String?
  authorId   String?
  content    String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?
  client     Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  work       Work?     @relation(fields: [workId], references: [id], onDelete: Cascade)
  invoice    Invoice?  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  budget     Budget?   @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  company    Company?  @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([clientId])
  @@index([workId])
  @@index([invoiceId])
  @@index([budgetId])
  @@index([archivedAt])
  @@index([companyId])
}

model Document {
  id           String           @id @default(cuid())
  companyId    String?
  name         String
  originalName String?
  mimeType     String?
  size         Int?
  storageKey   String?
  url          String?
  category     DocumentCategory @default(otro)
  clientId     String?
  workId       String?
  budgetId     String?
  invoiceId    String?
  expenseId    String?
  uploadedById String?
  metadata     Json?
