generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ClientStatus {
  nuevo
  pendiente_datos
  visita_pendiente
  presupuesto_pendiente
  presupuesto_enviado
  seguimiento_pendiente
  aceptado
  rechazado
  obra_activa
  finalizado
  pendiente_cobro
}

enum WorkStatus {
  borrador
  pendiente_aprobacion
  planificada
  preparacion
  pendiente_inicio
  en_curso
  pausada
  parcialmente_terminada
  pendiente_material
  pendiente_cliente
  parada
  pendiente_remates
  finalizada
  facturada_parcialmente
  facturada
  pendiente_cobro
  cobrada
  cerrada
  archivada
}

enum WorkPriority {
  baja
  media
  alta
  urgente
}

enum BudgetStatus {
  borrador
  pendiente_revision
  enviado
  visto
  pendiente_respuesta
  aceptado
  rechazado
  caducado
}

enum InvoiceStatus {
  borrador
  pendiente_emitir
  emitida
  enviada
  pendiente
  pendiente_pago
  parcialmente_pagada
  pagada
  vencida
  reclamada
}

enum PaymentType {
  senal
  pago_parcial
  pago_final
  regularizacion
}

enum ExpenseCategory {
  material
  mano_obra
  transporte
  herramienta
  gasolina
  subcontrata
  otros
}

enum ExpenseCashStatus {
  unknown
  pending
  paid
  cancelled
}

enum CostBehavior {
  unknown
  fixed
  variable
}

enum FinancialAccountType {
  bank
  cash
  other
}

enum CashMovementType {
  inflow
  outflow
  transfer_in
  transfer_out
  adjustment
}

enum CashMovementStatus {
  pending
  confirmed
  cancelled
}

enum CashMovementSource {
  manual
  generated
  adjustment
  bank_import
}

enum RecurringExpenseFrequency {
  weekly
  monthly
  quarterly
  yearly
  custom
}

enum ExpectedCashFlowType {
  expected_inflow
  expected_outflow
}

enum ExpectedCashFlowStatus {
  pending
  confirmed
  cancelled
}

enum ExpectedCashFlowSource {
  manual
  invoice
  expense
  recurring
  budget
  scenario
}

enum MaterialStatus {
  pendiente
  comprado
  entregado
  falta
  devuelto
}

enum ReminderType {
  seguimiento_presupuesto
  recordatorio_factura
  factura_vencida
  pedir_fotos
  pedir_medidas
  confirmar_visita
  material_pendiente
  recordatorio_interno
}

enum ReminderChannel {
  interno
  whatsapp
  email
}

enum ReminderStatus {
  borrador
  pendiente_confirmacion
  programado
  enviado
  cancelado
  fallido
  realizado
}

enum EventoAgendaTipo {
  visita
  llamada
  seguimiento_presupuesto
  seguimiento_cobro
  inicio_obra
  fin_previsto_obra
  compra_material
  recordatorio_interno
  vencimiento_factura
  presupuesto_pendiente
  tarea_obra
}

enum EventoAgendaEstado {
  pendiente
  confirmado
  realizado
  reprogramado
  cancelado
}

enum DocumentCategory {
  presupuesto
  factura
  contrato
  albaran
  ticket
  fotografia
  garantia
  certificado
  plano
  informe
  otro
}

enum NotificationPriority {
  baja
  media
  alta
  critica
}

model Client {
  id                        String         @id @default(cuid())
  nombre                    String
  nombreComercial           String?
  razonSocial               String?
  nifCif                    String?
  telefono                  String
  email                     String?
  direccion                 String
  direccionFiscal           String?
  codigoPostal              String?
  municipio                 String?
  provincia                 String?
  pais                      String         @default("España")
  emailFacturacion          String?
  telefonoFacturacion       String?
  contactoPrincipalNombre   String?
  contactoPrincipalCargo    String?
  contactoPrincipalTelefono String?
  contactoPrincipalEmail    String?
  contactoFacturacionNombre String?
  tipo                      String
  estado                    ClientStatus   @default(nuevo)
  origen                    String
  notas                     String?
  fechaCreacion             DateTime       @default(now())
  ultimaInteraccion         DateTime?
  archivadoAt               DateTime?
  budgets                   Budget[]
  contacts                  Contact[]
  documents                 Document[]
  expenses                  Expense[]
  invoices                  Invoice[]
  internalNotes             InternalNote[]
  payments                  Payment[]
  cashMovements             CashMovement[]
  expectedCashFlows         ExpectedCashFlow[]
  reminders                 Reminder[]
  works                     Work[]
  agendaEvents              EventoAgenda[]

  @@index([nombre])
  @@index([nifCif])
  @@index([email])
  @@index([telefono])
  @@index([estado])
  @@index([archivadoAt])
}

model Work {
  id                    String         @id @default(cuid())
  numeroInterno         String?        @unique
  codigo                String?        @unique
  clienteId             String
  contactoId            String?
  contactoPrincipal     String?
  contactoTelefono      String?
  contactoEmail         String?
  titulo                String
  direccion             String
  latitud               Float?
  longitud              Float?
  tipoTrabajo           String
  estado                WorkStatus     @default(pendiente_inicio)
  prioridad             WorkPriority   @default(media)
  fechaCreacion         DateTime       @default(now())
  fechaInicioPrevista   DateTime?
  fechaInicio           DateTime?
  fechaInicioReal       DateTime?
  fechaFinPrevista      DateTime?
  fechaFinReal          DateTime?
  responsable           String?
  comercial             String?
  jefeObra              String?
  descripcion           String?
  observacionesInternas String?
  notasPrivadas         String?
  presupuestoAprobado   Float
  costePrevisto         Float          @default(0)
  gastoReal             Float          @default(0)
  margenEstimado        Float          @default(0)
  horasEstimadas        Float          @default(0)
  horasReales           Float          @default(0)
  subcontratasCoste     Float          @default(0)
  archivada             Boolean        @default(false)
  archivadaAt           DateTime?
  notas                 String?
  updatedAt             DateTime       @updatedAt
  budgets               Budget[]
  client                Client         @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  contact               Contact?       @relation("WorkSiteContact", fields: [contactoId], references: [id], onDelete: SetNull)
  repositoryDocuments   Document[]
  documents             WorkDocument[]
  expenses              Expense[]
  internalNotes         InternalNote[]
  photos                WorkPhoto[]
  invoices              Invoice[]
  materials             Material[]
  payments              Payment[]
  cashMovements         CashMovement[]
  expectedCashFlows     ExpectedCashFlow[]
  recurringExpenses     RecurringExpense[]
  reminders             Reminder[]
  agendaEvents          EventoAgenda[]

  @@index([estado])
  @@index([prioridad])
  @@index([fechaInicioPrevista])
  @@index([fechaFinPrevista])
  @@index([archivada])
  @@index([contactoId])
}

model Contact {
  id               String         @id @default(cuid())
  clientId         String
  nombre           String
  apellidos        String?
  cargo            String?
  telefono         String?
  email            String?
  isPrimary        Boolean        @default(false)
  isBillingContact Boolean        @default(false)
  isSiteContact    Boolean        @default(false)
  notes            String?
  archivedAt       DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  client           Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  agendaEvents     EventoAgenda[]
  reminders        Reminder[]
  worksAsSite      Work[]         @relation("WorkSiteContact")

  @@index([clientId])
  @@index([email])
  @@index([telefono])
  @@index([archivedAt])
}

model WorkDocument {
  id         String   @id @default(cuid())
  obraId     String
  tipo       String
  nombre     String
  url        String?
  entityType String?
  entityId   String?
  notas      String?
  fecha      DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  work       Work     @relation(fields: [obraId], references: [id], onDelete: Cascade)

  @@index([obraId])
  @@index([tipo])
  @@index([entityType, entityId])
}

model WorkPhoto {
  id         String    @id @default(cuid())
  obraId     String
  documentId String?   @unique
  categoria  String
  titulo     String
  url        String?
  autor      String?
  ubicacion  String?
  notas      String?
  tomadaEn   DateTime  @default(now())
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  document   Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)
  work       Work      @relation(fields: [obraId], references: [id], onDelete: Cascade)

  @@index([obraId])
  @@index([categoria])
}

model Budget {
  id               String         @id @default(cuid())
  clienteId        String
  obraId           String?
  numero           String         @unique
  titulo           String
  partidas         String
  subtotal         Float
  iva              Float
  descuento        Float          @default(0)
  total            Float
  margenEstimado   Float
  estado           BudgetStatus   @default(borrador)
  fechaCreacion    DateTime       @default(now())
  fechaEnvio       DateTime?
  fechaValidez     DateTime?
  fechaSeguimiento DateTime?
  condiciones      String?
  observaciones    String?
  formaPago        String?
  client           Client         @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  agendaEvents     EventoAgenda[]
  documents        Document[]
  internalNotes    InternalNote[]
  reminders        Reminder[]
  work             Work?          @relation(fields: [obraId], references: [id])
}

model Invoice {
  id               String         @id @default(cuid())
  clienteId        String
  obraId           String?
  numero           String         @unique
  concepto         String
  partidas         String?
  importeBase      Float
  iva              Float
  total            Float
  pagado           Float          @default(0)
  pendiente        Float
  fechaEmision     DateTime
  fechaVencimiento DateTime
  estado           InvoiceStatus  @default(pendiente_pago)
  observaciones    String?
  metodoPago       String?
  datosBancarios   String?
  cashMovements    CashMovement[]
  client           Client         @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  agendaEvents     EventoAgenda[]
  documents        Document[]
  expectedCashFlows ExpectedCashFlow[]
  internalNotes    InternalNote[]
  payments         Payment[]
  reminders        Reminder[]
  work             Work?          @relation(fields: [obraId], references: [id])
}

model Payment {
  id        String      @id @default(cuid())
  facturaId String
  clienteId String
  obraId    String?
  importe   Float
  metodo    String
  fecha     DateTime    @default(now())
  tipo      PaymentType
  notas     String?
  cashMovements CashMovement[]
  client    Client      @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  invoice   Invoice     @relation(fields: [facturaId], references: [id], onDelete: Cascade)
  work      Work?       @relation(fields: [obraId], references: [id])
}

model Expense {
  id            String          @id @default(cuid())
  obraId        String
  clienteId     String?
  proveedor     String
  concepto      String
  categoria     ExpenseCategory
  importe       Float
  fecha         DateTime
  paymentStatus ExpenseCashStatus?
  paymentDueDate DateTime?
  paidAt        DateTime?
  costBehavior  CostBehavior     @default(unknown)
  fotoTicketUrl String?
  notas         String?
  cashMovements CashMovement[]
  client        Client?         @relation(fields: [clienteId], references: [id])
  documents     Document[]
  expectedCashFlows ExpectedCashFlow[]
  work          Work            @relation(fields: [obraId], references: [id], onDelete: Cascade)
}

model FinancialAccount {
  id                     String          @id @default(cuid())
  name                   String
  type                   FinancialAccountType @default(bank)
  currency               String          @default("EUR")
  openingBalance         Float           @default(0)
  currentManualBalance   Float?
  manualBalanceUpdatedAt DateTime?
  minimumBalance         Float?
  isActive               Boolean         @default(true)
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  archivedAt             DateTime?
  movements              CashMovement[]

  @@index([isActive])
  @@index([archivedAt])
}

model CashMovement {
  id              String             @id @default(cuid())
  accountId       String
  type            CashMovementType
  amount          Float
  date            DateTime
  description     String
  invoiceId       String?
  paymentId       String?            @unique
  expenseId       String?            @unique
  workId          String?
  clientId        String?
  category        String?
  provider        String?
  status          CashMovementStatus @default(confirmed)
  source          CashMovementSource @default(manual)
  transferGroupId String?
  notes           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  archivedAt      DateTime?
  account         FinancialAccount   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  client          Client?            @relation(fields: [clientId], references: [id], onDelete: SetNull)
  expense         Expense?           @relation(fields: [expenseId], references: [id], onDelete: SetNull)
  invoice         Invoice?           @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  payment         Payment?           @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  work            Work?              @relation(fields: [workId], references: [id], onDelete: SetNull)

  @@index([accountId, date])
  @@index([type])
  @@index([status])
  @@index([source])
  @@index([invoiceId])
  @@index([workId])
  @@index([clientId])
  @@index([transferGroupId])
  @@index([archivedAt])
}

model RecurringExpense {
  id          String                    @id @default(cuid())
  name        String
  amount      Float
  frequency   RecurringExpenseFrequency
  nextDueDate DateTime
  category    String?
  workId      String?
  provider    String?
  fixedCost   Boolean                   @default(true)
  isActive    Boolean                   @default(true)
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
  archivedAt  DateTime?
  work        Work?                     @relation(fields: [workId], references: [id], onDelete: SetNull)
  expectedCashFlows ExpectedCashFlow[]

  @@index([isActive, nextDueDate])
  @@index([workId])
  @@index([archivedAt])
}

model ExpectedCashFlow {
  id                 String                 @id @default(cuid())
  type               ExpectedCashFlowType
  amount             Float
  expectedDate       DateTime
  description        String
  probability        Float?
  confidenceSource   String?
  invoiceId          String?
  expenseId          String?
  recurringExpenseId String?
  workId             String?
  clientId           String?
  status             ExpectedCashFlowStatus @default(pending)
  source             ExpectedCashFlowSource @default(manual)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  archivedAt         DateTime?
  client             Client?                @relation(fields: [clientId], references: [id], onDelete: SetNull)
  expense            Expense?               @relation(fields: [expenseId], references: [id], onDelete: SetNull)
  invoice            Invoice?               @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  recurringExpense   RecurringExpense?      @relation(fields: [recurringExpenseId], references: [id], onDelete: SetNull)
  work               Work?                  @relation(fields: [workId], references: [id], onDelete: SetNull)

  @@index([expectedDate])
  @@index([type, status])
  @@index([source])
  @@index([invoiceId])
  @@index([expenseId])
  @@index([workId])
  @@index([clientId])
  @@index([archivedAt])
}

model TreasurySettings {
  id                    String   @id @default(cuid())
  currency              String   @default("EUR")
  minimumCashBalance    Float?
  safetyBuffer          Float?
  targetCoverageDays    Int?
  includeEstimatedInflows Boolean @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Material {
  id       String         @id @default(cuid())
  obraId   String
  nombre   String
  cantidad String
  estado   MaterialStatus @default(pendiente)
  notas    String?
  work     Work           @relation(fields: [obraId], references: [id], onDelete: Cascade)
}

model Reminder {
  id                   String          @id @default(cuid())
  clienteId            String?
  obraId               String?
  facturaId            String?
  presupuestoId        String?
  contactId            String?
  tipo                 ReminderType
  canal                ReminderChannel @default(interno)
  mensaje              String
  fechaProgramada      DateTime
  estado               ReminderStatus  @default(borrador)
  requiereConfirmacion Boolean         @default(true)
  confirmadoPorUsuario Boolean         @default(false)
  budget               Budget?         @relation(fields: [presupuestoId], references: [id])
  client               Client?         @relation(fields: [clienteId], references: [id])
  contact              Contact?        @relation(fields: [contactId], references: [id], onDelete: SetNull)
  invoice              Invoice?        @relation(fields: [facturaId], references: [id])
  work                 Work?           @relation(fields: [obraId], references: [id])
  agendaEvents         EventoAgenda[]

  @@index([contactId])
}

model EventoAgenda {
  id                   String             @id @default(cuid())
  titulo               String
  descripcion          String?
  tipo                 EventoAgendaTipo
  estado               EventoAgendaEstado @default(pendiente)
  fechaInicio          DateTime
  fechaFin             DateTime?
  horaInicio           String?
  horaFin              String?
  clienteId            String?
  obraId               String?
  presupuestoId        String?
  facturaId            String?
  recordatorioId       String?
  contactId            String?
  direccion            String?
  notas                String?
  requiereConfirmacion Boolean            @default(false)
  confirmadoPorUsuario Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  budget               Budget?            @relation(fields: [presupuestoId], references: [id])
  client               Client?            @relation(fields: [clienteId], references: [id])
  contact              Contact?           @relation(fields: [contactId], references: [id], onDelete: SetNull)
  invoice              Invoice?           @relation(fields: [facturaId], references: [id])
  reminder             Reminder?          @relation(fields: [recordatorioId], references: [id])
  work                 Work?              @relation(fields: [obraId], references: [id])

  @@index([contactId])
}

model InternalNote {
  id         String    @id @default(cuid())
  clientId   String?
  workId     String?
  invoiceId  String?
  budgetId   String?
  authorId   String?
  content    String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?
  client     Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  work       Work?     @relation(fields: [workId], references: [id], onDelete: Cascade)
  invoice    Invoice?  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  budget     Budget?   @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([workId])
  @@index([invoiceId])
  @@index([budgetId])
  @@index([archivedAt])
}

model Document {
  id           String           @id @default(cuid())
  name         String
  originalName String?
  mimeType     String?
  size         Int?
  storageKey   String?
  url          String?
  category     DocumentCategory @default(otro)
  clientId     String?
  workId       String?
  budgetId     String?
  invoiceId    String?
  expenseId    String?
  uploadedById String?
  metadata     Json?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  archivedAt   DateTime?
  client       Client?          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  work         Work?            @relation(fields: [workId], references: [id], onDelete: Cascade)
  budget       Budget?          @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  invoice      Invoice?         @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  expense      Expense?         @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  workPhoto    WorkPhoto?

  @@index([clientId])
  @@index([workId])
  @@index([budgetId])
  @@index([invoiceId])
  @@index([expenseId])
  @@index([category])
  @@index([archivedAt])
}

model Notification {
  id         String               @id @default(cuid())
  sourceKey  String               @unique
  type       String
  title      String
  body       String?
  href       String?
  priority   NotificationPriority @default(media)
  entityType String?
  entityId   String?
  readAt     DateTime?
  archivedAt DateTime?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  @@index([readAt])
  @@index([archivedAt])
  @@index([priority])
  @@index([entityType, entityId])
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  role           String
  content        String
  status         String           @default("saved")
  idempotencyKey String?          @unique
  context        Json?
  metadata       Json?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([status])
}

model ChatConversation {
  id             String        @id @default(cuid())
  title          String
  status         String        @default("active")
  activeTask     Json?
  metadata       Json?
  lastActivityAt DateTime      @default(now())
  archivedAt     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  messages       ChatMessage[]

  @@index([status, lastActivityAt])
  @@index([status, updatedAt])
}

model ChatActionLog {
  id             String   @id @default(cuid())
  conversationId String?
  messageId      String?
  stage          String
  actionType     String?
  status         String
  idempotencyKey String?
  summary        String?
  durationMs     Int?
  payload        Json?
  result         Json?
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  @@index([conversationId])
  @@index([idempotencyKey])
  @@index([messageId])
  @@index([stage])
  @@index([createdAt])
}

model UsuarioPerfil {
  id                     String   @id @default(cuid())
  nombre                 String?
  apellidos              String?
  tratamiento            String?
  nombrePreferido        String?
  telefono               String?
  email                  String?
  cargo                  String?
  oficioPrincipal        String?
  idioma                 String   @default("es-ES")
  zonaHoraria            String   @default("Europe/Madrid")
  preferenciaVisual      String   @default("sistema")
  notificacionesInternas Boolean  @default(true)
  notificacionesEmail    Boolean  @default(false)
  tonoPreferido          String   @default("directo")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model Empresa {
  id                     String   @id @default(cuid())
  nombreComercial        String
  razonSocial            String?
  nifCif                 String?
  direccionFiscal        String?
  codigoPostal           String?
  ciudad                 String?
  provincia              String?
  pais                   String   @default("España")
  municipio              String?
  telefono               String?
  email                  String?
  web                    String?
  personaContacto        String?
  iban                   String?
  condicionesPorDefecto  String?
  textoLegal             String?
  logoUrl                String?
  selloUrl               String?
  colorMarca             String   @default("#f6c945")
  ivaDefecto             Float    @default(21)
  moneda                 String   @default("EUR")
  validezPresupuestoDias Int      @default(15)
  formaPagoDefecto       String?
  seriePresupuestos      String   @default("2026")
  serieFacturas          String   @default("2026")
  serieObras             String   @default("2026")
  prefijoPresupuesto     String   @default("P")
  prefijoFactura         String   @default("F")
  prefijoObra            String   @default("OB")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}
