  id         String   @id @default(cuid())
  taskId     String
  entityType String
  entityId   String
  relation   String   @default("related")
  createdAt  DateTime @default(now())
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Restrict)

  @@unique([taskId, entityType, entityId, relation])
}

model TaskChecklistItem {
  id          String    @id @default(cuid())
  taskId      String
  title       String
  order       Int
  completed   Boolean   @default(false)
  completedAt DateTime?
  completedBy String?
  task        Task      @relation(fields: [taskId], references: [id], onDelete: Restrict)

  @@unique([taskId, order])
}

model TaskRecurrence {
  id                   String    @id @default(cuid())
  frequency            String
  rrule                String
  timezone             String    @default("Europe/Madrid")
  startsAt             DateTime
  endsAt               DateTime?
  nextOccurrenceAt     DateTime?
  generationWindowDays Int       @default(45)
  active               Boolean   @default(true)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  tasks                Task[]
  exdates              Json?

  @@index([active, nextOccurrenceAt])
}

model FollowUp {
  id               String            @id @default(cuid())
  title            String
  type             String            @default("general")
  status           FollowUpStatus    @default(planned)
  priority         FollowUpPriority  @default(medium)
  origin           String            @default("manual")
  companyId        String?
  createdById      String?
  responsibleId    String?
  clientId         String?
  contactId        String?
  workId           String?
  budgetId         String?
  invoiceId        String?
  recommendationId String?
  signalId         String?
  automationRunId  String?
  nextActionAt     DateTime?
  dueAt            DateTime?
  expectedOutcome  String?
  resultSummary    String?
  completedAt      DateTime?
  cancelledAt      DateTime?
  archivedAt       DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  automationRun    AutomationRun?    @relation(fields: [automationRunId], references: [id], onDelete: SetNull)
  attempts         FollowUpAttempt[]
  outcomes         FollowUpOutcome[]
  agendaEvents     EventoAgenda[]
  company          Company?          @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([status, nextActionAt])
  @@index([clientId, status])
  @@index([invoiceId, status])
  @@index([budgetId, status])
  @@index([companyId])
}

model FollowUpAttempt {
  id            String    @id @default(cuid())
  followUpId    String
  attemptedAt   DateTime  @default(now())
  channel       String
  responsibleId String?
  summary       String?
  response      String?
  nextActionAt  DateTime?
  createdAt     DateTime  @default(now())
  followUp      FollowUp  @relation(fields: [followUpId], references: [id], onDelete: Restrict)

  @@index([followUpId, attemptedAt])
}

model FollowUpOutcome {
  id           String   @id @default(cuid())
  followUpId   String
  type         String
  summary      String?
  recordedById String?
  recordedAt   DateTime @default(now())
  metadata     Json?
  followUp     FollowUp @relation(fields: [followUpId], references: [id], onDelete: Restrict)

  @@index([followUpId, recordedAt])
}

model User {
  id                  String                   @id @default(cuid())
  email               String
  emailNormalized     String                   @unique
  passwordHash        String
  displayName         String
  status              UserStatus               @default(pending_verification)
  emailVerifiedAt     DateTime?
  failedLoginCount    Int                      @default(0)
  lockedUntil         DateTime?
  lastLoginAt         DateTime?
  passwordChangedAt   DateTime                 @default(now())
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  memberships         CompanyMembership[]
  sessions            Session[]
  verificationTokens  EmailVerificationToken[]
  passwordResetTokens PasswordResetToken[]
  securityAuditEvents SecurityAuditEvent[]

  @@index([status])
}

model Company {
  id                  String                   @id @default(cuid())
  slug                String                   @unique
  nombreComercial     String
  razonSocial         String?
  taxId               String?
  email               String?
  telefono            String?
  direccion           String?
  codigoPostal        String?
  ciudad              String?
  provincia           String?
  pais                String                   @default("España")
  timezone            String                   @default("Europe/Madrid")
  locale              String                   @default("es-ES")
  status              CompanyStatus            @default(active)
  isDemo              Boolean                  @default(false)
  legacyEmpresaId     String?                  @unique
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  archivedAt          DateTime?
  web                 String?
  contactPerson       String?
  iban                String?
  defaultConditions   String?
  legalText           String?
  logoUrl             String?
  sealUrl             String?
  brandColor          String                   @default("#f6c945")
  defaultVat          Float                    @default(21)
  currency            String                   @default("EUR")
  budgetValidityDays  Int                      @default(15)
  defaultPaymentTerms String?
  budgetSeries        String                   @default("2026")
  invoiceSeries       String                   @default("2026")
  workSeries          String                   @default("2026")
  budgetPrefix        String                   @default("P")
  invoicePrefix       String                   @default("F")
  workPrefix          String                   @default("OB")
  memberships         CompanyMembership[]
  securityAuditEvents SecurityAuditEvent[]
  clients             Client[]
  contacts            Contact[]
  works               Work[]
  budgets             Budget[]
  invoices            Invoice[]
  payments            Payment[]
  expenses            Expense[]
  materials           Material[]
  documents           Document[]
  internalNotes       InternalNote[]
  reminders           Reminder[]
  agendaEvents        EventoAgenda[]
  notifications       Notification[]
  financialAccounts   FinancialAccount[]
  cashMovements       CashMovement[]
  recurringExpenses   RecurringExpense[]
  expectedCashFlows   ExpectedCashFlow[]
  chatConversations   ChatConversation[]
  signalStates        BusinessSignalState[]
  recommendations     BusinessRecommendation[]
  automations         AutomationDefinition[]
  automationRuns      AutomationRun[]
  tasks               Task[]
  followUps           FollowUp[]
  treasurySettings    TreasurySettings[]

  @@index([status])
  @@index([isDemo])
}

model CompanyMembership {
  id         String           @id @default(cuid())
  userId     String
  companyId  String
  role       CompanyRole      @default(MEMBER)
  status     MembershipStatus @default(invited)
  invitedAt  DateTime?
  acceptedAt DateTime?
  joinedAt   DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  user       User             @relation(fields: [userId], references: [id], onDelete: Restrict)
  company    Company          @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@unique([userId, companyId])
  @@index([companyId, status])
  @@index([userId, status])
}

model Session {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  lastSeenAt DateTime  @default(now())
  revokedAt  DateTime?
  userAgent  String?
  ipHash     String?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt, expiresAt])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt, expiresAt])
}

model PasswordResetToken {
  id          String    @id @default(cuid())
  userId      String
  tokenHash   String    @unique
  expiresAt   DateTime
  usedAt      DateTime?
  requestedAt DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt, expiresAt])
}

model SecurityAuditEvent {
  id        String               @id @default(cuid())
  companyId String?
  userId    String?
  type      String
  outcome   SecurityAuditOutcome
  requestId String?
  metadata  Json?
  createdAt DateTime             @default(now())
  company   Company?             @relation(fields: [companyId], references: [id], onDelete: SetNull)
  user      User?                @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([userId, createdAt])
  @@index([type, createdAt])
}
